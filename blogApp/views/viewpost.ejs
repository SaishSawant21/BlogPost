<%- include('partials/header.ejs') %>
    <% const post=singlePost %>
            <div class="d-flex flex-column min-vh-100">
                <div class="mx-auto mt-4" style="max-width: 1100px;">
    <a href="/" class="text-decoration-none accent-text">← Back to all posts</a>
  </div>
                <main class="flex-grow-1">
                    <div class="card my-5 card-accent border-secondary border-opacity-25 mx-auto"
                        style="max-width: 1100px;">
                        <div class="card-header navbar-custom">
                            <h5 class="card-title mb-0" style="color: #F5F0E8;">
                                <%= post.title %>
                            </h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text text-muted">
                                <%= post.content %>
                            </p>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <small class="text-muted">
                                <%= post.date %> · <%= post.readTime %> min read
                            </small>
                        </div>
                    </div>
                </main>
                <%- include('partials/footer.ejs') %>