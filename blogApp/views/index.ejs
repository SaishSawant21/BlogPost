<% let posts=postsData %>

    <%- include('partials/header.ejs') %>
        <div style="min-height: 100vh;">
            <div class="px-4 py-5 my-3 text-center">

                <h1 class="display-5 fw-semibold fs-2">
                    <%= posts.length> 0 ? 'Latest Posts' : 'Welcome to BlogPost' %>
                </h1>
                <div class="col-lg-6 mx-auto">
                    <p class="mb-4 text-muted">Stories, ideas, and thoughts from the community</p>
                    <a href="/newpost" class="btn btn-dark">Write a Post +</a>
                </div>
            </div>
            <% if (posts.length===0) { %>
                <div class="card text-center mx-auto mt-5 empty-state"
                    style="max-width: 380px; border: 1.5px dashed #C8762A !important;">
                    <div class="card-body py-5">
                        <div class="fs-1 mb-3">✏️</div>
                        <h5 class="card-title fw-bold">No posts yet.</h5>
                        <p class="card-text text-muted">
                            Be the first to share something. The page is blank — fill it.
                        </p>
                        <a href="/newpost" class="btn btn-dark mt-2">Write the first post</a>
                    </div>
                </div>
                <% }else{ %>
                    <div class="row row-cols-1 row-cols-md-2 g-4 mx-auto mt-2" style="max-width: 96%;">
                        <% posts.forEach(post=> { %>
                            <div class="col">
                                <div class="card h-100 card-accent border-secondary border-opacity-25">
                                    <div class="card-header navbar-custom">
                                        <h5 class="card-title mb-0" style="color: #F5F0E8;">
                                            <%= post.title %>
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        <p class="card-text text-muted">
                                            <%= post.content.substring(0, 120) %>...
                                        </p>
                                    </div>
                                    <div class="card-footer d-flex justify-content-between align-items-center">
                                        <small class="text-muted">
                                            <%= post.date %> · <%= post.readTime %> min read
                                        </small>
                                        <div class="d-flex align-items-center gap-3">
                                            <a href="/view-post/<%= post.id %>"
                                                class="text-decoration-none accent-text fw-500">Read more →</a>
                                            <a href="/edit-post/<%= post.id %>"
                                                class="text-decoration-none text-secondary" title="Edit">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                    fill="currentColor" viewBox="0 0 16 16">
                                                    <path
                                                        d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" />
                                                </svg>
                                            </a>
                                            <form action="/delete-post/<%= post.id %>" method="POST" class="d-inline">
                                                <button type="submit" class="btn btn-link text-danger p-0"
                                                    title="Delete">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                        fill="currentColor" viewBox="0 0 16 16">
                                                        <path
                                                            d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" />
                                                        <path
                                                            d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } %>
        </div>
        <%- include('partials/footer.ejs') %>